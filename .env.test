# Test Database Configuration - for testing only
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/didyouknow_test

# API Keys (test/stub values)
OPENROUTER_API_KEY=test_openrouter_key

# Application Configuration
ENVIRONMENT=test
LOG_LEVEL=DEBUG

# Platform API Keys (test values - will use mocks)
TWITTER_API_KEY=test_twitter_key
TWITTER_API_SECRET=test_twitter_secret
TWITTER_ACCESS_TOKEN=test_access_token
TWITTER_ACCESS_TOKEN_SECRET=test_access_token_secret

# Platform API test tokens
PINTEREST_BOARD_ID=test_board_id
PINTEREST_ACCESS_TOKEN=test_pinterest_token
INSTAGRAM_ACCESS_TOKEN=test_instagram_token

# PostgreSQL test-specific settings
PGSSLMODE=disable