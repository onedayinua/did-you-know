{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "PROJECT.md"],
  "provider": {
    "openrouter": {
      "models": {
        "qwen3-coder-next": { "id": "qwen/qwen3-coder-next" },
        "qwen3-coder-30b": { "id": "qwen/qwen3-coder-30b-a3b-instruct" },
        "qwen3-thinking": { "id": "qwen/qwen3-235b-a22b-thinking-2507" },
        "gemma-4-31b-it": { "id": "google/gemma-4-31b-it" },
        "deepseek-v3.2": { "id": "deepseek/deepseek-v3.2" },
        "deepseek-v4-flash": { "id": "deepseek/deepseek-v4-flash" },
        "grok-4.1": { "id": "x-ai/grok-4.1-fast" }
      }
    }
  },
  "agent": {
    "techlead": {
      "mode": "primary",
      "model": "openrouter/gemma-4-31b-it",
      "temperature": 0.6,
      "top_p": 0.95,
      "min_p": 0.05,
      "maxTokens": 16384,
      "extra_body": {
        "include_reasoning": true
      },
      "prompt": "{file:.opencode/agents/techlead.md}",
      "permission": {
        "bash": {
          "*": "deny",
          "git *": "allow",
          "ls *": "allow",
          "mv board/*": "allow",
          "cat board/*": "allow",
          "mkdir *": "allow"
        },
        "write": {
          "*": "deny",
          "*.md": "allow"
        },
        "edit": {
          "*": "deny",
          "*.md": "allow"
        }
      }
    },
    "developer": {
      "mode": "subagent",
      "model": "openrouter/deepseek-v4-flash",
      "temperature": 1.0,
      "top_p": 0.9,
      "min_p": 0.01,
      "maxTokens": 8192,
      "prompt": "{file:.opencode/agents/developer.md}",
      "permissions": {
        "bash": "allow",
        "write": "allow",
        "edit": "allow"
      }
    },
    "architect": {
      "mode": "primary",
      "model": "openrouter/gemma-4-31b-it",
      "temperature": 1.15,
      "top_p": 0.95,
      "min_p": 0.05,
      "prompt": "{file:.opencode/agents/architect.md}",
      "extra_body": {
        "include_reasoning": true
      },
      "permission": {
        "bash": "deny",
          "write": {
          "*": "deny",
          "*.md": "allow"
        },
        "edit": {
          "*": "deny",
          "*.md": "allow"
        }
      }
    },
    "qa": {
      "mode": "subagent",
      "model": "openrouter/gemma-4-31b-it",
      "temperature": 0.7,
      "min_p": 0.02,
      "prompt": "{file:.opencode/agents/qa.md}",
      "permission": {
        "bash": "allow"
      }
    },
    "writer": {
      "mode": "subagent",
      "model": "openrouter/deepseek-v4-flash",
      "temperature": 0.1,
      "min_p": 0.02,
      "prompt": "{file:.opencode/agents/writer.md}",
      "permission": {
        "bash": "deny",
          "write": {
          "*": "deny",
          "*.md": "allow"
        },
        "edit": {
          "*": "deny",
          "*.md": "allow"
        }
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "openrouter/gemma-4-31b-it",
      "temperature": 0.1,
      "min_p": 0.02,
      "prompt": "{file:.opencode/agents/reviewer.md}",
      "permission": {
        "bash": "deny",
          "write": {
          "*": "deny",
          "*.md": "allow"
        },
        "edit": {
          "*": "deny",
          "*.md": "allow"
        }
      }
    }
  },
  "plugin": [
    ".opencode/plugins/graphify.js"
  ]
}