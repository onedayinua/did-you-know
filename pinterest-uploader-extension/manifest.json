{
  "manifest_version": 3,
  "name": "Localhost Pinterest Pre-filler",
  "version": "1.0",
  "description": "Pre-fills Pinterest creation page with data from your local dashboard.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.pinterest.com/pin-creation-tool/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "host_permissions": [
    "https://*.pinterest.com/*",
    "http://localhost:8000/*", 
    "http://127.0.0.1:5500/*" 
  ]
}